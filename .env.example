# WorkBrew ‚Äî copy to `.env` and fill in API keys.
# `.env` is gitignored; keep secrets out of version control.

# Google Gemini (AI search + score_shops). https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Google Places API (New) ‚Äî used by `python backend/seed.py` for cafe data.
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Postgres ‚Äî must match `docker-compose` and backend URLs (user/password/db).
POSTGRES_USER=workbrew
POSTGRES_PASSWORD=workbrew
POSTGRES_DB=workbrew

# Optional. Default: host machine ‚Üí Postgres on localhost:5433 (compose port mapping).
# The backend service in Docker Compose sets this automatically to reach the `postgres` container.
# DATABASE_URL=postgresql://workbrew:workbrew@127.0.0.1:5433/workbrew
